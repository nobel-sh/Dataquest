# Runtime: development or production.
APP_ENV=development

# Database URL.
DATABASE_URL=sqlite:///./dataquest.db
# DATABASE_URL=postgresql+psycopg://dataquest:dataquest@127.0.0.1:5432/dataquest

# Comma-separated frontend origins allowed by CORS.
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# JWT signing secret. 
AUTH_SECRET_KEY=change-me-in-development

# Cookie security. Set all three to true in production.
ACCESS_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# AI provider: mock or gemini.
AI_PROVIDER=mock
GEMINI_MODEL=gemini-flash-latest
GEMINI_API_KEY=
